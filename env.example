# קובץ דוגמה - העתק אותו ל-.env ומלא את הערכים האמיתיים

# Railway יספק את ה-URL הזה אוטומטית
DATABASE_URL=postgresql://user:password@host:port/database

# יצור מפתח חזק לאימות JWT (לפחות 32 תווים)
# אפשר להשתמש ב: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=your-super-secret-jwt-key-here-change-this

# סביבת הרצה
NODE_ENV=production

# פורט (Railway יגדיר אוטומטית)
PORT=3000

# הגדרות SMTP לשליחת מיילים (לאיפוס סיסמה)
# הגדרות עבור Zoho Mail
SMTP_HOST=smtp.zoho.com
SMTP_PORT=587
SMTP_USER=info@ecodos.co.il
SMTP_PASS=your-zoho-password
